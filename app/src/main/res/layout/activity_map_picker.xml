<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Header overlay -->
    <RelativeLayout
        android:id="@+id/headerMap"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="#CC00796B"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnVoltarMap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Voltar"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@android:color/white"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/txtTituloMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Marcar localização"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Tip below header -->
    <TextView
        android:id="@+id/txtDicaMapa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerMap"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:background="#CC000000"
        android:padding="6dp"
        android:text="Toque no mapa para marcar o local"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <!-- Coords display -->
    <TextView
        android:id="@+id/txtCoordenadasMap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomBarMap"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="8dp"
        android:background="#CC000000"
        android:padding="6dp"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBarMap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#CC00796B"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnMinhaLocalizacao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Minha Localização"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnConfirmarLocal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Confirmar"
            android:textSize="13sp" />
    </LinearLayout>

</RelativeLayout>
